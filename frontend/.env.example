# Clerk Authentication (get from Clerk Dashboard -> API Keys)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# Clerk JWT for Convex (get from Clerk Dashboard -> Convex Integration)
# Format: https://verb-noun-00.clerk.accounts.dev
CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api.clerk.accounts.dev

# Convex Backend (get from Convex Dashboard)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
